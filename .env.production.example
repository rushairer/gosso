# gosso Production Environment Configuration
# Copy this file to .env.production and fill in real values.

# Application
APP_PORT=8080
APP_EXTERNAL_PORT=8080
GIN_MODE=release
DEBUG=false

# PostgreSQL (REQUIRED — set a strong password)
POSTGRES_DB=gosso
POSTGRES_USER=gosso
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# SMTP (for password reset, verification emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-domain.com

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
