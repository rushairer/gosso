# gosso Production Environment Configuration
# Copy this file to .env.production and fill in real values.

# Application
APP_PORT=8080
APP_EXTERNAL_PORT=8080
GIN_MODE=release
DEBUG=false

# PostgreSQL (REQUIRED — set a strong password)
POSTGRES_DB=gosso
POSTGRES_USER=gosso
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth (REQUIRED — configure RSA key for JWT signing and real issuer URL)
GOUNO_AUTH_ISSUER=https://your-domain.com
GOUNO_AUTH_PRIVATE_KEY_PATH=/app/keys/private.pem
GOUNO_AUTH_KEY_ID=gosso-key-1
GOUNO_AUTH_PASSWORD_RESET_BASE_URL=https://your-domain.com/reset-password

# TOTP Encryption (REQUIRED for production — 64-char hex, 32 bytes)
# Generate with: openssl rand -hex 32
GOUNO_AUTH_TOTP_ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX_STRING

# SMTP (for password reset, verification emails)
GOUNO_SMTP_HOST=smtp.example.com
GOUNO_SMTP_PORT=587
GOUNO_SMTP_USERNAME=
GOUNO_SMTP_PASSWORD=
GOUNO_SMTP_FROM=noreply@your-domain.com
GOUNO_SMTP_TLS_POLICY=mandatory

# CORS
GOUNO_CORS_ALLOWED_ORIGINS=https://your-domain.com

# Database DSN for the bundled docker-compose Postgres service.
# Use sslmode=disable only when the database server does not support TLS.
GOUNO_DATABASE_DRIVERS_POSTGRES_DSN=postgres://gosso:CHANGE_ME_STRONG_PASSWORD@postgres:5432/gosso?sslmode=require&TimeZone=Asia/Shanghai

# Redis DSN (must include REDIS_PASSWORD when Redis requirepass is enabled)
GOUNO_REDIS_DSN=redis://:CHANGE_ME_STRONG_PASSWORD@redis:6379/0

# OAuth Providers (optional — leave empty to disable)
# GOUNO_OAUTH_PROVIDERS_GOOGLE_CLIENT_ID=
# GOUNO_OAUTH_PROVIDERS_GOOGLE_CLIENT_SECRET=
# GOUNO_OAUTH_PROVIDERS_GOOGLE_REDIRECT_URI=
# GOUNO_OAUTH_PROVIDERS_GITHUB_CLIENT_ID=
# GOUNO_OAUTH_PROVIDERS_GITHUB_CLIENT_SECRET=
# GOUNO_OAUTH_PROVIDERS_GITHUB_REDIRECT_URI=
# GOUNO_OAUTH_PROVIDERS_WECHAT_CLIENT_ID=
# GOUNO_OAUTH_PROVIDERS_WECHAT_CLIENT_SECRET=
# GOUNO_OAUTH_PROVIDERS_WECHAT_REDIRECT_URI=

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
