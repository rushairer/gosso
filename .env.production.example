# gosso Production Environment Configuration
# Copy this file to .env.production and fill in real values.

# Application
export APP_PORT=8080
export APP_EXTERNAL_PORT=8080
export GIN_MODE=release
export DEBUG=false

# PostgreSQL (REQUIRED — set a strong password)
export POSTGRES_DB=gosso
export POSTGRES_USER=gosso
export POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
export POSTGRES_HOST=postgres
export POSTGRES_PORT=5432

# Redis
export REDIS_HOST=redis
export REDIS_PORT=6379
export REDIS_DATABASE=0
export REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# SMTP (for password reset, verification emails)
export SMTP_HOST=smtp.example.com
export SMTP_PORT=587
export SMTP_USERNAME=
export SMTP_PASSWORD=
export SMTP_FROM=noreply@your-domain.com

# Nginx
export NGINX_HTTP_PORT=80
export NGINX_HTTPS_PORT=443
