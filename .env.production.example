# gosso Production Environment Configuration
# Copy this file to .env.production and fill in real values.

# Application
export APP_PORT=8080
export APP_EXTERNAL_PORT=8080
export GIN_MODE=release
export DEBUG=false

# PostgreSQL (REQUIRED — set a strong password)
export POSTGRES_DB=gosso
export POSTGRES_USER=gosso
export POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
export POSTGRES_HOST=postgres
export POSTGRES_PORT=5432

# Redis
export REDIS_HOST=redis
export REDIS_PORT=6379
export REDIS_DATABASE=0
export REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth (REQUIRED — configure RSA key for JWT signing and real issuer URL)
export GOUNO_AUTH_ISSUER=https://your-domain.com
export GOUNO_AUTH_PRIVATE_KEY_PATH=/app/keys/private.pem
export GOUNO_AUTH_KEY_ID=gosso-key-1
export GOUNO_PASSWORD_RESET_BASE_URL=https://your-domain.com/reset-password

# SMTP (for password reset, verification emails)
export GOUNO_SMTP_HOST=smtp.example.com
export GOUNO_SMTP_PORT=587
export GOUNO_SMTP_USERNAME=
export GOUNO_SMTP_PASSWORD=
export GOUNO_SMTP_FROM=noreply@your-domain.com
export GOUNO_SMTP_TLS_POLICY=opportunistic

# CORS
export GOUNO_CORS_ORIGIN=https://your-domain.com

# Database DSN (must match the GOUNO_DATABASE_DRIVERS_POSTGRES_DSN key in production.yaml)
export GOUNO_DATABASE_DRIVERS_POSTGRES_DSN=host=postgres user=gosso password=CHANGE_ME_STRONG_PASSWORD dbname=gosso port=5432 sslmode=disable TimeZone=Asia/Shanghai

# Redis DSN
export GOUNO_REDIS_DSN=redis://redis:6379/0

# OAuth Providers (optional — leave empty to disable)
# export GOUNO_GOOGLE_CLIENT_ID=
# export GOUNO_GOOGLE_CLIENT_SECRET=
# export GOUNO_GOOGLE_REDIRECT_URI=
# export GOUNO_GITHUB_CLIENT_ID=
# export GOUNO_GITHUB_CLIENT_SECRET=
# export GOUNO_GITHUB_REDIRECT_URI=
# export GOUNO_WECHAT_CLIENT_ID=
# export GOUNO_WECHAT_CLIENT_SECRET=
# export GOUNO_WECHAT_REDIRECT_URI=

# Nginx
export NGINX_HTTP_PORT=80
export NGINX_HTTPS_PORT=443
