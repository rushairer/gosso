# gosso Test Environment Configuration
# Copy this file to .env.test and fill in values.

APP_PORT=8080
APP_EXTERNAL_PORT=8082
GIN_MODE=test
DEBUG=true
POSTGRES_DB=gosso_test
POSTGRES_USER=gosso
POSTGRES_PASSWORD=CHANGE_ME_TEST_PASSWORD
